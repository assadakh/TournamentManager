<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.tournamentmanager.controller.ManageTournamentController"
      spacing="15" style="-fx-background-color: #f0f2f5;">

    <!-- Header -->
    <VBox style="-fx-background-color: #2c3e50; -fx-padding: 15 20;">
        <Label fx:id="labelTournament" text="Gestion du tournoi"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
    </VBox>

    <!-- Contenu -->
    <VBox spacing="15" style="-fx-padding: 20;">

        <HBox spacing="15" alignment="CENTER">

            <!-- Liste gauche : disponibles -->
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Joueurs disponibles :"
                       style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                <ListView fx:id="listDisponibles" prefHeight="200" prefWidth="200"/>
            </VBox>

            <!-- Boutons flèches -->
            <VBox spacing="10" alignment="CENTER">
                <Button text=">" onAction="#handleAjouterJoueur" prefWidth="40"
                        style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                <Button text="&lt;" onAction="#handleRetirerJoueur" prefWidth="40"
                        style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
            </VBox>

            <!-- Liste droite : inscrits -->
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Joueurs inscrits :"
                       style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                <ListView fx:id="listInscrits" prefHeight="200" prefWidth="200"/>
            </VBox>

        </HBox>

        <Label fx:id="labelError" style="-fx-text-fill: #e74c3c; -fx-font-size: 13px;"/>

        <Button text="🏆  Générer le bracket"
                onAction="#handleGenererBracket"
                prefWidth="200"
                style="-fx-font-size: 14px;"/>

    </VBox>

</VBox>
