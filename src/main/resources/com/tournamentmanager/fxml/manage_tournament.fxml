<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.tournamentmanager.controller.ManageTournamentController"
      spacing="15" style="-fx-background-color: #f0f2f5;">

    <!-- Header -->
    <VBox style="-fx-background-color: #2c3e50; -fx-padding: 15 20;">
        <Label fx:id="labelTournament" text="Gestion du tournoi"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
    </VBox>

    <!-- Contenu -->
    <VBox spacing="15" style="-fx-padding: 20;">

        <Label text="Joueurs inscrits :"
               style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
        <ListView fx:id="listPlayers" prefHeight="180"/>

        <Label text="Ajouter un joueur :"
               style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <ComboBox fx:id="comboPlayers" prefWidth="200"/>
            <Button text="➕  Ajouter" onAction="#handleAjouterJoueur"/>
        </HBox>

        <Button text="🏆  Générer le bracket"
                onAction="#handleGenererBracket"
                prefWidth="200"
                style="-fx-font-size: 14px;"/>

    </VBox>

</VBox>