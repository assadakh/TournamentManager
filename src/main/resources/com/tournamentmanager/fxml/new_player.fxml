<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.tournamentmanager.controller.NewPlayerController"
      spacing="15" style="-fx-background-color: #f0f2f5;">

    <VBox style="-fx-background-color: #2c3e50; -fx-padding: 15 20;">
        <Label text="👤 Nouveau Joueur"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
    </VBox>

    <VBox spacing="12" style="-fx-padding: 20;">
        <TextField fx:id="fieldName" promptText="Pseudo du joueur"/>
        <TextField fx:id="fieldGame" promptText="Jeu pratiqué"/>
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="Annuler" onAction="#handleAnnuler"/>
            <Button text="✅  Créer" onAction="#handleCreer"/>
        </HBox>
    </VBox>

</VBox>