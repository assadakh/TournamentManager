<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.tournamentmanager.controller.NewPlayerController">

    <Label text="Nouveau joueur"/>
    <TextField fx:id="fieldName" promptText="Nom du joueur"/>
    <TextField fx:id="fieldGame" promptText="Nom du jeu"/>
    <HBox>
        <Button text="Effacer" onAction="#handleAnnuler"/>
        <Button text="Confirmer" onAction="#handleCreer"/>
    </HBox>

</VBox>