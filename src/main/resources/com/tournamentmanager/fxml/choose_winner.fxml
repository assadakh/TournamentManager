<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.tournamentmanager.controller.ChooseWinnerController"
      spacing="15" style="-fx-background-color: #f0f2f5;">

    <VBox style="-fx-background-color: #2c3e50; -fx-padding: 15 20;">
        <Label text="🏅 Choisir le gagnant"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
    </VBox>

    <VBox spacing="12" style="-fx-padding: 20;" alignment="CENTER">
        <Label text="Qui a gagné ce match ?"
               style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;"/>
        <Button fx:id="btnPlayer1" onAction="#handlePlayer1"
                prefWidth="200" prefHeight="40"
                style="-fx-font-size: 14px;"/>
        <Button fx:id="btnPlayer2" onAction="#handlePlayer2"
                prefWidth="200" prefHeight="40"
                style="-fx-font-size: 14px;"/>
    </VBox>

</VBox>